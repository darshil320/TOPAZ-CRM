# Required
API_URL=https://your-api-host.com
API_KEY=change-me-at-least-32-chars

# Optional — defaults shown
CAMERA_SOURCE=0               # USB index or RTSP URL, e.g. rtsp://192.168.1.200/stream
CAMERA_ID=entrance-1
COOLDOWN_SECONDS=30
QUALITY_FLOOR=0.4
REQUEST_TIMEOUT_SECONDS=10
FRAME_POLL_SECONDS=0.01

# §19-E consent seam:
#   kiosk = poll the API for a pending kiosk consent token (production default)
#   open  = attach a static test token to every detection (bench testing only)
#   off   = drop every detection (strict privacy mode)
CONSENT_MODE=kiosk
CONSENT_POLL_SECONDS=2

# Required when Layer 3 consent kiosk is wired (§19-E)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
