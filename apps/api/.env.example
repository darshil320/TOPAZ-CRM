# Topaz CRM API — environment variables
# Copy to .env and fill in real values before running.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────────────────────────────
# Pre-shared key sent by the edge worker in the API-Key header.
EDGE_API_KEY=change_me_at_least_32_chars

# Pre-shared key used by Next.js server actions to call /api/whatsapp/send.
DASHBOARD_API_KEY=change_me_at_least_32_chars

# ── Recognition tuning ────────────────────────────────────────────────────────
MATCH_THRESHOLD=0.45
NEW_THRESHOLD=0.30
HNSW_EF_SEARCH=40

# ── WhatsApp Cloud API (Meta) ─────────────────────────────────────────────────
# Leave unset in local dev to skip real WA sends (logs a warning instead).
# WA_PHONE_NUMBER_ID=123456789012345
# WA_TOKEN=EAAxxxxxxxxxxxxxx            # System User permanent token (not the 24h dev token)
# WA_WEBHOOK_VERIFY_TOKEN=random_string_you_choose
# WA_APP_SECRET=xxxxxxxxxxxxxxxx        # Meta App Secret — verifies webhook signatures.
#                                       # UNSET = webhook signature NOT checked (dev only).

# ── AI drafts ─────────────────────────────────────────────────────────────────
# Unset = follow-up drafts fall back to the built-in template text.
# ANTHROPIC_API_KEY=sk-ant-xxxx

# ── Kiosk consent seam (§19-E) ────────────────────────────────────────────────
# How long a kiosk enrollment stays claimable by the entrance camera (seconds).
ENROLLMENT_PENDING_WINDOW_SECONDS=120

# ── Cadence engine (Celery beat) ──────────────────────────────────────────────
WELCOME_FOLLOWUP_DELAY_MINUTES=120
FOLLOWUP_BATCH_SIZE=25
FOLLOWUP_STALE_DAYS=3

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_URL=https://topaz.dmcdigital.in
