# Copy to .env and adjust. The prototype runs with ZERO config in console mode.

# ── Notifier ──────────────────────────────────────────────────────────────────
# console  → prints alerts (no creds, default; verify the flow first)
# twilio   → real WhatsApp via Twilio sandbox (easiest live demo)
# aisensy  → production BSP (WhatsApp Business Platform)
NOTIFIER=console

# Default WhatsApp recipient for owner alerts (E.164). For the killer demo, set this
# to Hemant's own number so HE gets the buzz when he steps in front of the camera.
OWNER_WHATSAPP=+919426529230
SHOWROOM_NAME=Topaz

# ── Photo attachment + web view ─────────────────────────────────────────────────
# The web view (python -m src.web) serves captured photos at /captures/<file>.
# To attach those photos to WhatsApp alerts, expose the web view publicly and set
# PUBLIC_BASE_URL to that address, e.g.:
#     python -m src.web              # in one terminal
#     ngrok http 8077                # in another  -> gives https://xxxx.ngrok.io
#     PUBLIC_BASE_URL=https://xxxx.ngrok.io
# Leave PUBLIC_BASE_URL empty → alerts are text-only (still work).
PUBLIC_BASE_URL=
WEB_PORT=8077

# ── Recognition tuning (optional; sensible defaults in code) ────────────────────
MATCH_THRESHOLD=0.45
NEW_THRESHOLD=0.30
ALERT_COOLDOWN_SECONDS=120
MODEL_NAME=buffalo_l
PROVIDER=cpu          # cpu | cuda
CAMERA_INDEX=0

# ── Twilio (only if NOTIFIER=twilio) ────────────────────────────────────────────
# Join the sandbox once from each phone (send the join code per Twilio console).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── AiSensy (only if NOTIFIER=aisensy) ──────────────────────────────────────────
# Requires an approved template campaign in AiSensy.
AISENSY_API_KEY=
AISENSY_CAMPAIGN_NAME=
